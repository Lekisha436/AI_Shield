<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} | AI Digital Shield</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <span class="material-symbols-outlined">shield</span>
            </div>
            <div>
                <div class="brand-name">AI Digital Shield</div>
                <div class="brand-status">
                    <span class="status-dot"></span> All Systems Secure
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <a href="/" class="nav-item {{#if (eq active 'dashboard')}}active{{/if}}">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a href="/scan" class="nav-item {{#if (eq active 'scan')}}active{{/if}}">
                <span class="material-symbols-outlined">radar</span>
                <span>Threat Scanner</span>
            </a>
            <a href="/alerts" class="nav-item {{#if (eq active 'alerts')}}active{{/if}}">
                <span class="material-symbols-outlined">notifications_active</span>
                <span>Alert Log</span>
            </a>
            <a href="/chat" class="nav-item {{#if (eq active 'chat')}}active{{/if}}">
                <span class="material-symbols-outlined">smart_toy</span>
                <span>Shield Assistant</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <button class="lockdown-btn" onclick="triggerLockdown()">
                <span class="material-symbols-outlined">gpp_bad</span>
                Emergency Lockdown
            </button>
        </div>
    </aside>

    <!-- Top Bar -->
    <header class="topbar">
        <button class="menu-toggle" onclick="toggleSidebar()">
            <span class="material-symbols-outlined">menu</span>
        </button>
        <div class="topbar-title">{{title}}</div>
        <div class="topbar-actions">
            <span class="topbar-time" id="live-time"></span>
            <div class="topbar-avatar">AS</div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main-content">
        {{{body}}}
    </main>

    <!-- Lockdown Modal -->
    <div class="modal-overlay" id="lockdown-modal">
        <div class="modal-box">
            <span class="material-symbols-outlined modal-icon danger">gpp_bad</span>
            <h2>Emergency Lockdown</h2>
            <p>This will isolate all network connections and freeze suspicious processes. Are you sure?</p>
            <div class="modal-actions">
                <button class="btn-danger" onclick="confirmLockdown()">Activate Lockdown</button>
                <button class="btn-secondary" onclick="closeLockdown()">Cancel</button>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
    {{#if pageScript}}<script src="/js/{{pageScript}}"></script>{{/if}}
</body>
</html>
